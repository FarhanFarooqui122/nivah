generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  clerkId   String   @unique
  createdAt DateTime @default(now())

  documents Document[]
}

model Document {
  id          String   @id @default(cuid())
  title       String
  fileName    String
  fileType    String
  fileSize    Int
  fileUrl     String
  createdAt   DateTime @default(now())

  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
